#!/bin/sh
set -e

echo "🔍 Running pre-push checks..."

tmp_dir=$(mktemp -d)
status=0

cleanup() {
    rm -rf "$tmp_dir"
}
trap cleanup EXIT

run_check() {
    label=$1
    log_file=$2
    shift 2

    echo "▶ $label"

    set +e
    "$@" > "$log_file" 2>&1
    code=$?
    set -e

    if [ "$code" -eq 0 ]; then
        echo "✅ $label"
        return 0
    fi

    echo "❌ $label"
    cat "$log_file"
    return "$code"
}

run_check "1/5 format:check" "$tmp_dir/format-check.log" yarn format:check &
pid_format=$!

run_check "2/5 lint" "$tmp_dir/lint.log" yarn lint &
pid_lint=$!

wait "$pid_format" || status=1
wait "$pid_lint" || status=1

run_check "3/5 typecheck" "$tmp_dir/typecheck.log" yarn typecheck || status=1
run_check "4/5 test" "$tmp_dir/test.log" yarn test:quiet || status=1
run_check "5/5 build" "$tmp_dir/build.log" yarn build || status=1

if [ "$status" -ne 0 ]; then
    echo ""
    echo "❌ Pre-push checks failed. Push aborted."
    exit 1
fi

echo ""
echo "✅ All checks passed. Proceeding with push."
