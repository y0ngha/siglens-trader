# Auth — set to true in .env.local for local development without Cloudflare Access
DISABLE_AUTH=

# Vercel Cron
CRON_SECRET=

# siglens-core infra (shared instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
WORKER_URL=
WORKER_SECRET=

# Data sources
FMP_API_KEY=
MARKET_DATA_PROVIDER=fmp

# BYOK — LLM premium models (activated per analysis type in dashboard)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Toss Securities Open API (OAuth2 client_credentials)
TOSS_APP_KEY=          # OAuth2 client_id
TOSS_SECRET_KEY=       # OAuth2 client_secret
# TOSS_ACCOUNT_NO removed — accountSeq resolved dynamically via GET /api/v1/accounts

# DB
DATABASE_URL=

# Notifications
RESEND_API_KEY=
NOTIFICATION_EMAIL_FROM=noreply@siglens.io
