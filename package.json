{
    "name": "siglens-trader",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "author": "신용하 <dev.y0ngha@gmail.com>",
    "license": "MITLICENSE",
    "scripts": {
        "dev": "vite",
        "dev:mock": "VITE_API_MOCK=true vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "lint:staged": "eslint --fix",
        "lint:style": "stylelint --allow-empty-input '**/*.{css,scss}'",
        "lint:style-fix": "stylelint --fix '**/*.{css,scss}'",
        "test": "vitest run",
        "test:quiet": "vitest run --silent --reporter=dot",
        "test:related": "vitest related --run --passWithNoTests",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "format:staged": "prettier --write --ignore-unknown",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "tsx --env-file=.env.local lib/db/migrate.ts",
        "db:seed": "tsx --env-file=.env.local lib/db/seed.ts",
        "db:clear": "tsx --env-file=.env.local lib/db/clear.ts",
        "prepare": "husky",
        "release": "release-it",
        "release:patch": "release-it patch",
        "release:minor": "release-it minor",
        "release:major": "release-it major"
    },
    "dependencies": {
        "@neondatabase/serverless": "^1.1.0",
        "@tanstack/react-query": "^5.95.2",
        "@upstash/redis": "^1.37.0",
        "@vercel/functions": "^3.4.3",
        "@y0ngha/siglens-core": "0.21.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-error-boundary": "^6.1.1",
        "react-markdown": "^10.1.0",
        "react-router": "^7.6.2",
        "resend": "^6.12.2",
        "tailwind-merge": "^3.5.0",
        "yahoo-finance2": "3.14.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.28.0",
        "@release-it/conventional-changelog": "^10.0.6",
        "@tailwindcss/vite": "^4",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.9.1",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^4.5.2",
        "@vitest/coverage-v8": "^3.2.4",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.2.0",
        "husky": "^9.1.7",
        "jsdom": "^26.1.0",
        "lint-staged": "^17.0.5",
        "msw": "^2.14.6",
        "prettier": "^3.7.4",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "release-it": "^19.2.4",
        "stylelint": "^17.0.0",
        "stylelint-config-recess-order": "^7.4.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-order": "^7.0.0",
        "tailwindcss": "^4",
        "tsx": "^4.19.4",
        "typescript": "^5",
        "typescript-eslint": "^8.33.1",
        "vite": "^6.3.5",
        "vite-plugin-pwa": "^1.0.0",
        "vitest": "^3.2.1"
    },
    "packageManager": "yarn@4.12.0",
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
